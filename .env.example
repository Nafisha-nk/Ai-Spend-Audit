NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CREDEX_BOOKING_URL=https://credex.rocks

# Anthropic summary generation. The app falls back to a deterministic summary if unset.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase REST backend. Required for production/deployed submissions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email. The app skips email in local dev if unset.
RESEND_API_KEY=
RESEND_FROM=AI Spend Audit <audit@yourdomain.com>

# Optional internal notice address for high-savings lead alerts.
CREDEX_LEADS_TO=
